---
import Base from '../layouts/Base.astro';
---
<Base title="Architecture">
  <section class="container" style="padding: var(--space-lg) var(--space-md);">
    <h1>Architecture</h1>
    <p style="color: var(--ink-muted); max-width: 640px; margin-bottom: var(--space-md);">
      The editorial system diagram for Project Ground Zero. Canonical source lives in the project repo.
    </p>
    <p>
      👉 <a href="https://raw.githack.com/sowthri-industrial-ai/project-00-ground-zero/main/html/architecture.html" target="_blank" rel="noopener">Open the full architecture document</a>
    </p>
    <p style="margin-top: var(--space-md); color: var(--ink-muted);">
      <small>Rendered from the project repo via <code>raw.githack.com</code> · GitHub doesn't render HTML files directly.</small>
    </p>
  </section>
</Base>
