---
import Base from '../layouts/Base.astro';
---
<Base title="Architecture">
  <section class="container" style="padding: var(--space-lg) var(--space-md);">
    <h1>System Architecture</h1>
    <p style="color: var(--ink-muted); max-width: 640px; margin-bottom: var(--space-md);">
      Editorial system diagram for Project Ground Zero · rendered inline below · also available as a <a href="/genai-portfolio-hub/architecture.html" target="_blank" rel="noopener">standalone page</a>.
    </p>

    <div style="margin: var(--space-md) 0; border: 1px solid var(--grid-line); border-radius: 4px; overflow: hidden; background: var(--paper);">
      <iframe
        src="/genai-portfolio-hub/architecture.html"
        style="width: 100%; height: 90vh; border: 0; display: block;"
        title="Project Ground Zero Architecture"
      ></iframe>
    </div>

    <div style="margin-top: var(--space-md); padding: var(--space-sm); background: var(--paper-dark); border-radius: 4px;">
      <p style="font-size: var(--text-sm); margin: 0;">
        <strong>Source</strong>: <a href="https://github.com/sowthri-industrial-ai/project-00-ground-zero/blob/main/html/architecture.html" target="_blank" rel="noopener">View on GitHub</a> ·
        <a href="/genai-portfolio-hub/architecture.html" target="_blank" rel="noopener">Open full page</a>
      </p>
    </div>
  </section>
</Base>
