---
import Base from '../layouts/Base.astro';

// Ledger fetcher · build-time · reads from project-00 repo
// Wave-2 scaffold · Brief D spec says newest-first · REJECTED visible (honesty principle)

let entries: any[] = [];
try {
  const res = await fetch('https://raw.githubusercontent.com/sowthri-industrial-ai/project-00-ground-zero/main/as-built/ledger.jsonl');
  if (res.ok) {
    const text = await res.text();
    entries = text.trim().split('\n').filter(Boolean).map(line => JSON.parse(line)).reverse();
  }
} catch (e) {
  console.warn('Ledger fetch failed · showing placeholder');
}

const statusColors: Record<string, string> = {
  success:   'var(--status-live)',
  failure:   'var(--status-down)',
  cancelled: 'var(--ink-muted)',
  skipped:   'var(--status-sleeping)',
};
---
<Base title="As-built Ledger">
  <section class="container" style="padding: var(--space-lg) var(--space-md);">
    <h1>As-built Ledger</h1>
    <p style="color: var(--ink-muted); max-width: 640px; margin-bottom: var(--space-md);">
      Newest first. Every deploy and teardown is recorded. Failures stay visible — honesty over theater.
    </p>

    {entries.length === 0 ? (
      <p class="mono" style="color: var(--ink-muted); padding: var(--space-md); background: var(--paper-dark); border-radius: 4px;">
        No entries yet · Wave 4 activates real deploys
      </p>
    ) : (
      <div>
        {entries.map((e) => (
          <div style="padding: var(--space-xs); border-bottom: 1px solid var(--grid-line); display: grid; grid-template-columns: 180px 1fr 100px auto; gap: var(--space-sm); align-items: center;">
            <span class="mono" style="font-size: var(--text-xs); color: var(--ink-muted);">{e.timestamp}</span>
            <span class="mono">{e.action}</span>
            <span class="mono" style={`font-size: var(--text-xs); color: ${statusColors[e.status] || 'var(--ink)'}; text-transform: uppercase;`}>{e.status}</span>
            <span class="mono" style="font-size: var(--text-xs); color: var(--ink-muted);">@{e.actor}</span>
          </div>
        ))}
      </div>
    )}
  </section>
</Base>
