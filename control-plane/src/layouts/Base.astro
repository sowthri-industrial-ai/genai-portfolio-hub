---
import '../styles/tokens.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'GenAI Architect Portfolio · Industrial AI' } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <title>{title} · GenAI Architect Portfolio</title>
</head>
<body>
  <header class="container" style="padding-top: var(--space-md); padding-bottom: var(--space-md); border-bottom: 1px solid var(--grid-line);">
    <nav style="display: flex; justify-content: space-between; align-items: center;">
      <a href="/genai-portfolio-hub/" style="text-decoration: none; color: var(--ink);">
        <strong class="serif" style="font-size: var(--text-lg);">Sowthri</strong>
        <span class="mono" style="font-size: var(--text-xs); color: var(--ink-muted); margin-left: var(--space-sm);">· GenAI Architect Portfolio</span>
      </a>
      <div style="display: flex; gap: var(--space-sm);">
        <a href="/genai-portfolio-hub/projects" style="font-size: var(--text-sm);">Projects</a>
        <a href="/genai-portfolio-hub/architecture" style="font-size: var(--text-sm);">Architecture</a>
        <a href="/genai-portfolio-hub/ledger" style="font-size: var(--text-sm);">Ledger</a>
        <a href="/genai-portfolio-hub/about" style="font-size: var(--text-sm);">About</a>
      </div>
    </nav>
  </header>
  <main>
    <slot />
  </main>
  <footer class="container" style="padding: var(--space-lg) var(--space-md); text-align: center; color: var(--ink-muted); font-size: var(--text-sm); border-top: 1px solid var(--grid-line); margin-top: var(--space-xl);">
    <p>Dammam, KSA · 2026 · Built on <span class="mono">Astro 5</span></p>
  </footer>
</body>
</html>
